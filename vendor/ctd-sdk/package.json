{
  "name": "@ctd/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Client SDK for the confidential token demo: Grumpkin/Poseidon2 crypto, UltraHonk proving, RPC-only chain + state sync. Vendored (prebuilt dist + circuits) from brozorec/stellar-confidential-token-demo — see VENDORED.md.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brozorec/stellar-confidential-token-demo.git",
    "directory": "packages/sdk"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./state/json-store": {
      "types": "./dist/state/json-store.d.ts",
      "import": "./dist/state/json-store.js"
    },
    "./circuits/*": "./circuits/*"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "circuits"
  ],
  "dependencies": {
    "@aztec/bb.js": "0.87.0",
    "@noble/curves": "^1.9.4",
    "@noble/hashes": "^1.8.0",
    "@noir-lang/noir_js": "1.0.0-beta.9",
    "@stellar/stellar-sdk": "^14.2.0",
    "@zkpassport/poseidon2": "^0.6.0"
  }
}
